# Never expose this key with NEXT_PUBLIC_. It is only read by server route handlers.
OPENAI_API_KEY=sk-proj-your-key

# Recommended default for this MVP. Override it if a newer realtime model is available to your account.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Optional: used after the call to generate the written coaching report.
OPENAI_FEEDBACK_MODEL=gpt-4.1-mini
